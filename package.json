{
  "name": "emo-ai-companion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder --linux --armv7l",
    "electron:build:arm64": "vite build && electron-builder --linux --arm64",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.emo.ai-companion",
    "productName": "EMO AI Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "arm64",
            "armv7l"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "arm64",
            "armv7l"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    }
  }
}
